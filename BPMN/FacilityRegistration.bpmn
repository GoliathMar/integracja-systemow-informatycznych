    <bpmn:sequenceFlow id="Flow_Biz4" sourceRef="Catch_SuccessFromAdmin" targetRef="End_Biznes" />
  </bpmn:process>
  <bpmn:process id="Process_Admin" isExecutable="false">
    <bpmn:startEvent id="Start_Admin_Req" name="Otrzymanie zlecenia">
      <bpmn:outgoing>Flow_Adm1</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>
    <bpmn:task id="Task_Admin1" name="Analiza zlecenia">
