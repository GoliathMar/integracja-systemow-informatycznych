  <bpmn:collaboration id="Collab_VisitCancelationPatient">
    <bpmn:participant id="Pool_VisitCancelationPatient" name="Anulowanie wizyty przez pacjenta" processRef="Process_VisitCancelationPatient" />
  </bpmn:collaboration>
  <bpmn:process id="Process_VisitCancelationPatient" name="Anulowanie wizyty przez pacjenta" isExecutable="false">
    <bpmn:laneSet id="LaneSet_VisitCancelationPatient">
      <bpmn:lane id="Lane_Patient" name="Pacjent">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RequestCancel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyRefundReception</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0q642w8</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="System">
        <bpmn:flowNodeRef>Task_CheckPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PaymentMethod</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RefundGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RefundSuccess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyRefundProcessed</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Pacjent chce anulować wizytę">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_RequestCancel" name="Zgłoś anulowanie wizyty">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_0og13pn</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_CheckPayment" name="Sprawdź status i metodę płatności wizyty">
      <bpmn:incoming>Flow_0og13pn</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_PaymentMethod" name="Opłacono przez bramkę?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RefundGateway" name="Zleć zwrot przez bramkę płatniczą">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_RefundSuccess" name="Zwrot przez bramkę udany?">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_NotifyRefundProcessed" name="Poinformuj: zwrot został zlecony i przetworzony">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_1qn3elu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_1" name="Anulowanie zakończone&#10;ze zwrotem">
      <bpmn:incoming>Flow_12</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_RequestCancel" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_CheckPayment" targetRef="Gateway_PaymentMethod" />
    <bpmn:sequenceFlow id="Flow_4" name="tak" sourceRef="Gateway_PaymentMethod" targetRef="Task_RefundGateway" />
    <bpmn:sequenceFlow id="Flow_5" name="nie / opłata w recepcji" sourceRef="Gateway_PaymentMethod" targetRef="Task_NotifyRefundReception" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_RefundGateway" targetRef="Gateway_RefundSuccess" />
    <bpmn:sequenceFlow id="Flow_7" name="tak" sourceRef="Gateway_RefundSuccess" targetRef="Task_NotifyRefundProcessed" />
    <bpmn:sequenceFlow id="Flow_8" name="nie" sourceRef="Gateway_RefundSuccess" targetRef="Task_NotifyRefundReception" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_ReceiveInfo" targetRef="EndEvent_1" />
    <bpmn:userTask id="Task_ReceiveInfo" name="Pacjent odbiera informację o zwrocie">
      <bpmn:incoming>Flow_1qn3elu</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0og13pn" sourceRef="Task_RequestCancel" targetRef="Task_CheckPayment" />
    <bpmn:userTask id="Task_NotifyRefundReception" name="Poinformuj: zwrot czeka w recepcji">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_1peagk5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_0q642w8" name="Anulowanie zakończone">
      <bpmn:incoming>Flow_1peagk5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1peagk5" sourceRef="Task_NotifyRefundReception" targetRef="Event_0q642w8" />
    <bpmn:sequenceFlow id="Flow_1qn3elu" sourceRef="Task_NotifyRefundProcessed" targetRef="Task_ReceiveInfo" />
  </bpmn:process>
