        <di:waypoint x="1140" y="278" />
        <di:waypoint x="1140" y="233" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="S_End_P3_Firma" bpmnElement="End_P3_Firma">
        <dc:Bounds x="1240" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1213" y="245" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_DO_P3_PlanDnia" bpmnElement="DO_P3_PlanDnia">
        <dc:Bounds x="555" y="290" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="535" y="345" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Annot_P3_DwaKanaly" bpmnElement="Annot_P3_DwaKanaly">
        <dc:Bounds x="750" y="356" width="340" height="56" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_SF_P3_1" bpmnElement="SF_P3_1">
        <di:waypoint x="228" y="220" />
        <di:waypoint x="290" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_SF_P3_2" bpmnElement="SF_P3_2">
        <di:waypoint x="450" y="220" />
        <di:waypoint x="520" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_SF_P3_3" bpmnElement="SF_P3_3">
        <di:waypoint x="680" y="220" />
        <di:waypoint x="750" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_SF_P3_4" bpmnElement="SF_P3_4">
        <di:waypoint x="1190" y="220" />
        <di:waypoint x="1240" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Assoc_P3_DwaKanaly" bpmnElement="Assoc_P3_DwaKanaly">
        <di:waypoint x="970" y="340" />
        <di:waypoint x="920" y="356" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="S_Pool_P3_Kier" bpmnElement="Pool_P3_Kierowca" isHorizontal="true">
        <dc:Bounds x="120" y="450" width="1200" height="240" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start_P3_Kier" bpmnElement="Start_P3_Kierowca">
        <dc:Bounds x="192" y="552" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="175" y="595" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
