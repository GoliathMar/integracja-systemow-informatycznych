<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_ClerkRegistrationAdmin" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:collaboration id="Collab_ClerkRegistrationAdmin">
    <bpmn:participant id="Pool_Registration" name="Rejestracja pracownika" processRef="Process_ClerkRegistrationAdmin" />
    <bpmn:participant id="Participant_1ahnl3u" name="Pracownik rejestracji" />
    <bpmn:participant id="Participant_1nlshvf" name="Zarządca placówki" />
    <bpmn:messageFlow id="Flow_070mk1z" sourceRef="Event_08xcvdv" targetRef="Participant_1ahnl3u" />
    <bpmn:messageFlow id="Flow_0vhvr3b" sourceRef="Participant_1nlshvf" targetRef="StartEvent_1" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ClerkRegistrationAdmin" name="Zakładanie konta rejestracji przez admina" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Registration">
      <bpmn:lane id="Lane_Admin" name="Administrator">
        <bpmn:flowNodeRef>Task_EnterData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectRole</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="System">
        <bpmn:flowNodeRef>Gateway_DataValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreateAccount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GenerateCredentials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Validate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_08xcvdv</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="Task_EnterData" name="Wprowadź dane pracownika rejestracji">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_1i757ci</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SelectRole" name="Wybierz rolę i placówkę">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_EnterData" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_EnterData" targetRef="Task_SelectRole" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_SelectRole" targetRef="Task_Validate" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Validate" targetRef="Gateway_DataValid" />
    <bpmn:exclusiveGateway id="Gateway_DataValid" name="Dane poprawne?">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_1i757ci</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_CreateAccount" name="Utwórz konto użytkownika">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_GenerateCredentials" name="Wygeneruj login i hasło tymczasowe, a następnie wyślij informacje do pracownika">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_1cdzvrs</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_5" name="tak" sourceRef="Gateway_DataValid" targetRef="Task_CreateAccount" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_CreateAccount" targetRef="Task_GenerateCredentials" />
    <bpmn:serviceTask id="Task_Validate" name="Zweryfikuj kompletność i duplikaty">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1i757ci" name="nie" sourceRef="Gateway_DataValid" targetRef="Task_EnterData" />
    <bpmn:sequenceFlow id="Flow_1cdzvrs" sourceRef="Task_GenerateCredentials" targetRef="Event_08xcvdv" />
    <bpmn:endEvent id="Event_08xcvdv">
      <bpmn:incoming>Flow_1cdzvrs</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1m09cih" />
    </bpmn:endEvent>
    <bpmn:startEvent id="StartEvent_1" name="Wniosek o nowe konto">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0iig2ax" />
    </bpmn:startEvent>
  </bpmn:process>
