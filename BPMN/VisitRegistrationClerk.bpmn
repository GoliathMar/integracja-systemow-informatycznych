        <bpmndi:BPMNLabel>
          <dc:Bounds x="1573" y="103" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_10" bpmnElement="Flow_10">
        <di:waypoint x="1810" y="160" />
