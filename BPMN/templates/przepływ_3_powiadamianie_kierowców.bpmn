        <dc:Bounds x="520" y="530" width="160" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_P3_Kier" bpmnElement="End_P3_Kierowca">
        <dc:Bounds x="752" y="552" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="728" y="595" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Annot_K3_BrakWer" bpmnElement="Annot_K3_BrakWeryfikacji">
        <dc:Bounds x="520" y="630" width="300" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_SF_K3_1" bpmnElement="SF_K3_1">
