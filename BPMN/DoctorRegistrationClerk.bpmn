        <dc:Bounds x="850" y="265" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_SendSys_di" bpmnElement="Event_SendSys">
        <dc:Bounds x="970" y="287" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="957" y="250" width="63" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_CatchConfirm_di" bpmnElement="Event_CatchConfirm">
        <dc:Bounds x="1150" y="137" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1135" y="100" width="67" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Rec_di" bpmnElement="EndEvent_Rec">
        <dc:Bounds x="1250" y="137" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1231" y="180" width="75" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="155" />
        <di:waypoint x="300" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="400" y="155" />
        <di:waypoint x="450" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="550" y="155" />
        <di:waypoint x="600" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="650" y="195" />
        <di:waypoint x="650" y="265" />
      </bpmndi:BPMNEdge>
