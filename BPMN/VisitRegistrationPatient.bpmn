<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_VisitRegistrationPatient" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:collaboration id="Collab_VisitRegistrationPatient">
    <bpmn:participant id="Pool_VisitRegistrationPatient" name="Rejestracja wizyty przez pacjenta" processRef="Process_VisitRegistrationPatient" />
  </bpmn:collaboration>
  <bpmn:process id="Process_VisitRegistrationPatient" name="Rejestracja wizyty przez pacjenta" isExecutable="false">
    <bpmn:laneSet id="LaneSet_VisitRegistrationPatient">
      <bpmn:lane id="Lane_Patient" name="Pacjent">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectDoctorFacility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectVisitSlot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PayGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1dujlkt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Success</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Boundary_PaymentTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Expired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PaymentFailed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="System">
        <bpmn:flowNodeRef>Task_ValidateSlot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReserveSlot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StartQueueTimer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0tuvv1s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PaymentSuccess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AddToDoctorSchedule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendVisitNotification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReleaseSlot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyPaymentFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckPaymentStatus</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1r5tbg8</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Pacjent chce zarejestrować wizytę">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_SelectDoctorFacility" name="Wybierz lekarza i placówkę na stronie">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SelectVisitSlot" name="Wybierz termin wizyty">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_1lh3ykm</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ValidateSlot" name="Sprawdź dostępność terminu">
      <bpmn:incoming>Flow_1er70w5</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ReserveSlot" name="Tymczasowo zajmij miejsce">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_StartQueueTimer" name="Uruchom kolejkę płatności i limit czasu transakcji">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_PayGateway" name="Opłać wizytę przez bramkę płatniczą">
      <bpmn:incoming>Flow_0yolgv3</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_SelectDoctorFacility" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_SelectDoctorFacility" targetRef="Task_SelectVisitSlot" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_SelectVisitSlot" targetRef="Event_0tuvv1s" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_ValidateSlot" targetRef="Task_ReserveSlot" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ReserveSlot" targetRef="Task_StartQueueTimer" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_StartQueueTimer" targetRef="Event_1dujlkt" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_PayGateway" targetRef="Event_1r5tbg8" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_CheckPaymentStatus" targetRef="Gateway_PaymentSuccess" />
    <bpmn:sequenceFlow id="Flow_Timeout_1" sourceRef="Boundary_PaymentTimeout" targetRef="Task_ReleaseSlot" />
    <bpmn:boundaryEvent id="Boundary_PaymentTimeout" name="Limit czasu płatności minął" attachedToRef="Task_PayGateway">
      <bpmn:outgoing>Flow_Timeout_1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0lehbbt">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT10M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:intermediateCatchEvent id="Event_0tuvv1s">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_1er70w5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_19og0ej" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1er70w5" sourceRef="Event_0tuvv1s" targetRef="Task_ValidateSlot" />
    <bpmn:intermediateThrowEvent id="Event_1dujlkt">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:incoming>Flow_1lh3ykm</bpmn:incoming>
      <bpmn:outgoing>Flow_0yolgv3</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1txwrqq" />
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="Flow_1lh3ykm" sourceRef="Task_SelectVisitSlot" targetRef="Event_1dujlkt" />
    <bpmn:sequenceFlow id="Flow_0yolgv3" sourceRef="Event_1dujlkt" targetRef="Task_PayGateway" />
    <bpmn:exclusiveGateway id="Gateway_PaymentSuccess" name="Płatność zakończona sukcesem?">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_AddToDoctorSchedule" name="Dodaj wizytę do grafiku lekarza">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SendVisitNotification" name="Wyślij potwierdzenie wizyty do pacjenta">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ReleaseSlot" name="Zwolnij zajęte miejsce terminu">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:incoming>Flow_Timeout_1</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_NotifyTimeout" name="Poinformuj o przekroczeniu czasu płatności">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_NotifyPaymentFailed" name="Poinformuj o nieudanej płatności">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_9" name="tak" sourceRef="Gateway_PaymentSuccess" targetRef="Task_AddToDoctorSchedule" />
    <bpmn:sequenceFlow id="Flow_10" name="nie" sourceRef="Gateway_PaymentSuccess" targetRef="Task_ReleaseSlot" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_AddToDoctorSchedule" targetRef="Task_SendVisitNotification" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_SendVisitNotification" targetRef="EndEvent_Success" />
    <bpmn:sequenceFlow id="Flow_13" name="timeout" sourceRef="Task_ReleaseSlot" targetRef="Task_NotifyTimeout" />
    <bpmn:sequenceFlow id="Flow_14" name="nieudana płatność" sourceRef="Task_ReleaseSlot" targetRef="Task_NotifyPaymentFailed" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_NotifyTimeout" targetRef="EndEvent_Expired" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_NotifyPaymentFailed" targetRef="EndEvent_PaymentFailed" />
    <bpmn:serviceTask id="Task_CheckPaymentStatus" name="Zweryfikuj status płatności">
      <bpmn:incoming>Flow_1hfr6cp</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="Event_1r5tbg8">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_1hfr6cp</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1x4ilxl" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1hfr6cp" sourceRef="Event_1r5tbg8" targetRef="Task_CheckPaymentStatus" />
    <bpmn:endEvent id="EndEvent_Success" name="Wizyta zarejestrowana">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0v5b3px" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Expired" name="Rejestracja anulowana - czas minął">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1ok8tjy" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_PaymentFailed" name="Rejestracja anulowana - płatność nieudana">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1sam817" />
    </bpmn:endEvent>
  </bpmn:process>
