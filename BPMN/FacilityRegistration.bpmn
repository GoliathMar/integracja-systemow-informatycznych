    <bpmn:messageFlow id="Msg_AdminToBiz" name="Raport o sukcesie" sourceRef="End_Admin_Success" targetRef="Catch_SuccessFromAdmin" />
    <bpmn:messageFlow id="MsgFlow_1" name="Żądanie formularza" sourceRef="Throw_ReqForm" targetRef="Start_Sys_Req" />
