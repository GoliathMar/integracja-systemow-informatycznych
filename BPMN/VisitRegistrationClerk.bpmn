      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Participant_0pg27wj_di" bpmnElement="Pool_VisitRegistrationClerk_Patient" isHorizontal="true">
        <dc:Bounds x="120" y="-90" width="2560" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_MF_PatientToClerk" bpmnElement="Flow_VisitReg_PatientToClerk">
        <di:waypoint x="220" y="-30" />
        <di:waypoint x="220" y="142" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_MF_RegisteredToPatient" bpmnElement="Flow_VisitReg_SystemToPatient">
        <di:waypoint x="2520" y="142" />
        <di:waypoint x="2520" y="-30" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_MF_FailedToPatient" bpmnElement="Flow_Reg_FailedToPatient">
