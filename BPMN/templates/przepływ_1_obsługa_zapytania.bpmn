<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_P1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:message id="Msg_Zapytanie" name="Zapytanie o transport" />
  <bpmn:collaboration id="Collab_P1">
    <bpmn:participant id="Pool_Kontrahent" name="Kontrahent" processRef="Proc_Kontrahent" />
    <bpmn:participant id="Pool_FirmaTransp" name="XYZ Transport (Biuro)" processRef="Proc_FirmaTransp" />
    <bpmn:participant id="Pool_Transport" name="Kierowca / Transport" processRef="Proc_Transport" />
    <bpmn:messageFlow id="MF_ZapytanieDoFirmy" name="Zgłoszenie zapytania" sourceRef="Task_ZlozZapytanie" targetRef="Start_ZapytanieWplywa" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_Kontrahent" isExecutable="false">
    <bpmn:startEvent id="Start_Kontrahent" name="Potrzeba transportu">
      <bpmn:outgoing>SF_K1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_ZlozZapytanie" name="Złóż zapytanie o transport">
      <bpmn:incoming>SF_K1</bpmn:incoming>
      <bpmn:outgoing>SF_K2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_KontrahentOtrzymalOdp" name="Odpowiedź otrzymana">
      <bpmn:incoming>SF_K2</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_K_End" messageRef="Msg_Zapytanie" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_K1" sourceRef="Start_Kontrahent" targetRef="Task_ZlozZapytanie" />
    <bpmn:sequenceFlow id="SF_K2" sourceRef="Task_ZlozZapytanie" targetRef="End_KontrahentOtrzymalOdp" />
  </bpmn:process>
  <bpmn:process id="Proc_FirmaTransp" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Biuro">
      <bpmn:lane id="Lane_Biuro" name="Biuro (Koordynator)">
        <bpmn:flowNodeRef>Start_ZapytanieWplywa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_NatychmiastowyCzyPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SprawdzDostepnosc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_KontaktOdmowa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Odmowa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Merge_P1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AktualizujExcel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Zaplanowany</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProc_Planowanie</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_ZapytanieWplywa" name="Zapytanie wpłynęło">
      <bpmn:outgoing>SF_F1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Start" messageRef="Msg_Zapytanie" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_NatychmiastowyCzyPlan" name="Natychmiastowy?">
      <bpmn:incoming>SF_F1</bpmn:incoming>
      <bpmn:outgoing>SF_F2_Natychmiastowy</bpmn:outgoing>
      <bpmn:outgoing>SF_F3_Plan</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SprawdzDostepnosc" name="Sprawdź dostępność kierowcy i pojazdu (Excel)">
      <bpmn:incoming>SF_F2_Natychmiastowy</bpmn:incoming>
      <bpmn:outgoing>SF_F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_KontaktOdmowa" name="Skontaktuj się z klientem — odmowa">
      <bpmn:incoming>SF_F5_PlanNie</bpmn:incoming>
      <bpmn:outgoing>SF_F8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Odmowa" name="Transport odmówiony">
      <bpmn:incoming>SF_F8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="SubProc_Planowanie" name="Planowanie transportu">
      <bpmn:incoming>SF_F3_Plan</bpmn:incoming>
      <bpmn:outgoing>SF_F5_PlanOK</bpmn:outgoing>
      <bpmn:outgoing>SF_F5_PlanNie</bpmn:outgoing>
      <bpmn:startEvent id="Start_SubPlan" name="Planowanie rozpoczęte">
        <bpmn:outgoing>SF_SP1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:task id="Task_AnalizujDostepnosc" name="Analizuj arkusz dostępności">
        <bpmn:incoming>SF_SP1</bpmn:incoming>
        <bpmn:outgoing>SF_SP2</bpmn:outgoing>
      </bpmn:task>
      <bpmn:exclusiveGateway id="GW_CzyMozliwy" name="Transport możliwy?">
        <bpmn:incoming>SF_SP2</bpmn:incoming>
        <bpmn:outgoing>SF_SP3_Tak</bpmn:outgoing>
        <bpmn:outgoing>SF_SP3_Nie</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="End_SubPlanOK" name="Transport zaplanowany">
        <bpmn:incoming>SF_SP3_Tak</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:endEvent id="End_SubPlanNie" name="Zaplanowanie niemożliwe">
        <bpmn:incoming>SF_SP3_Nie</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="SF_SP1" sourceRef="Start_SubPlan" targetRef="Task_AnalizujDostepnosc" />
      <bpmn:sequenceFlow id="SF_SP2" sourceRef="Task_AnalizujDostepnosc" targetRef="GW_CzyMozliwy" />
      <bpmn:sequenceFlow id="SF_SP3_Tak" name="tak" sourceRef="GW_CzyMozliwy" targetRef="End_SubPlanOK" />
      <bpmn:sequenceFlow id="SF_SP3_Nie" name="nie" sourceRef="GW_CzyMozliwy" targetRef="End_SubPlanNie" />
    </bpmn:subProcess>
    <bpmn:exclusiveGateway id="GW_Merge_P1" name="">
      <bpmn:incoming>SF_F4</bpmn:incoming>
      <bpmn:incoming>SF_F5_PlanOK</bpmn:incoming>
      <bpmn:outgoing>SF_F6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AktualizujExcel" name="Aktualizuj arkusz transportów">
      <bpmn:incoming>SF_F6</bpmn:incoming>
      <bpmn:outgoing>SF_F7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Zaplanowany" name="Transport zaplanowany / przydzielony">
      <bpmn:incoming>SF_F7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_F1" sourceRef="Start_ZapytanieWplywa" targetRef="GW_NatychmiastowyCzyPlan" />
    <bpmn:sequenceFlow id="SF_F2_Natychmiastowy" name="natychmiastowy" sourceRef="GW_NatychmiastowyCzyPlan" targetRef="Task_SprawdzDostepnosc" />
    <bpmn:sequenceFlow id="SF_F3_Plan" name="do zaplanowania" sourceRef="GW_NatychmiastowyCzyPlan" targetRef="SubProc_Planowanie" />
    <bpmn:sequenceFlow id="SF_F4" sourceRef="Task_SprawdzDostepnosc" targetRef="GW_Merge_P1" />
    <bpmn:sequenceFlow id="SF_F5_PlanNie" name="niemożliwy" sourceRef="SubProc_Planowanie" targetRef="Task_KontaktOdmowa" />
    <bpmn:sequenceFlow id="SF_F8" sourceRef="Task_KontaktOdmowa" targetRef="End_Odmowa" />
    <bpmn:sequenceFlow id="SF_F5_PlanOK" name="zaplanowany" sourceRef="SubProc_Planowanie" targetRef="GW_Merge_P1" />
    <bpmn:sequenceFlow id="SF_F6" sourceRef="GW_Merge_P1" targetRef="Task_AktualizujExcel" />
    <bpmn:sequenceFlow id="SF_F7" sourceRef="Task_AktualizujExcel" targetRef="End_Zaplanowany" />
  </bpmn:process>
  <bpmn:process id="Proc_Transport" isExecutable="false">
    <bpmn:startEvent id="Start_KierowcaOtrzymalZlecenie" name="Zlecenie otrzymane">
      <bpmn:outgoing>SF_T1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_T_Start" />
    </bpmn:startEvent>
    <bpmn:task id="Task_RealizacjaTransportu" name="Realizacja transportu">
      <bpmn:incoming>SF_T1</bpmn:incoming>
      <bpmn:outgoing>SF_T2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_TransportZrealizowany" name="Transport zrealizowany">
      <bpmn:incoming>SF_T2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_T1" sourceRef="Start_KierowcaOtrzymalZlecenie" targetRef="Task_RealizacjaTransportu" />
    <bpmn:sequenceFlow id="SF_T2" sourceRef="Task_RealizacjaTransportu" targetRef="End_TransportZrealizowany" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_P1">
    <bpmndi:BPMNPlane id="BPMNPlane_P1" bpmnElement="Collab_P1">
      <bpmndi:BPMNShape id="S_Pool_Kontrahent" bpmnElement="Pool_Kontrahent" isHorizontal="true">
