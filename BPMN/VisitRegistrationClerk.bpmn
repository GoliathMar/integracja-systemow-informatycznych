        <bpmndi:BPMNLabel>
          <dc:Bounds x="1132" y="265" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_7" bpmnElement="Flow_7">
        <di:waypoint x="1195" y="160" />
