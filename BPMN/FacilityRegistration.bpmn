      <bpmn:outgoing>Flow_Adm7</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="Gateway_Admin" name="Czy dodano pomyślnie?">
