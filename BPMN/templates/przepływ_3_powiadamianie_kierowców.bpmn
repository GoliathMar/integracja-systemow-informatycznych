        <bpmndi:BPMNLabel>
          <dc:Bounds x="915" y="194" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_P3_Merge" bpmnElement="GW_P3_Merge" isMarkerVisible="true">
        <dc:Bounds x="1115" y="183" width="50" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_SF_SP3_1" bpmnElement="SF_SP3_1">
        <di:waypoint x="818" y="208" />
        <di:waypoint x="855" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_SF_SP3_Chat" bpmnElement="SF_SP3_Chat">
        <di:waypoint x="880" y="183" />
        <di:waypoint x="880" y="148" />
        <di:waypoint x="960" y="148" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="887" y="153" width="71" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_SF_SP3_Tel" bpmnElement="SF_SP3_Tel">
        <di:waypoint x="880" y="233" />
        <di:waypoint x="880" y="278" />
        <di:waypoint x="950" y="278" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="885" y="278" width="62" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_SF_SP3_ChatMerge" bpmnElement="SF_SP3_ChatMerge">
        <di:waypoint x="1100" y="148" />
        <di:waypoint x="1140" y="148" />
        <di:waypoint x="1140" y="183" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_SF_SP3_TelMerge" bpmnElement="SF_SP3_TelMerge">
