<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_VisitRegistrationClerk" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:collaboration id="Collab_VisitRegistrationClerk">
    <bpmn:participant id="Pool_VisitRegistrationClerk" name="Rejestracja wizyty przez recepcjonistę" processRef="Process_VisitRegistrationClerk" />
    <bpmn:participant id="Pool_VisitRegistrationClerk_Patient" name="Pacjent" />
    <bpmn:messageFlow id="Flow_VisitReg_PatientToClerk" sourceRef="Pool_VisitRegistrationClerk_Patient" targetRef="StartEvent_1" />
    <bpmn:messageFlow id="Flow_VisitReg_SystemToPatient" sourceRef="EndEvent_Registered" targetRef="Pool_VisitRegistrationClerk_Patient" />
    <bpmn:messageFlow id="Flow_Reg_FailedToPatient" sourceRef="EndEvent_Cancelled" targetRef="Pool_VisitRegistrationClerk_Patient" />
  </bpmn:collaboration>
  <bpmn:process id="Process_VisitRegistrationClerk" name="Rejestracja wizyty przez recepcjonistę" isExecutable="false">
    <bpmn:laneSet id="LaneSet_VisitRegistrationClerk">
      <bpmn:lane id="Lane_Clerk" name="Recepcjonista">
        <bpmn:flowNodeRef>Gateway_PatientAcceptsAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Registered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Cancelled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CollectPatientData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectPreferredSlot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProposeAlternativeSlot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AssignDoctor</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="System">
        <bpmn:flowNodeRef>Gateway_SlotAvailable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ValidateSlotAvailability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AddVisitToDoctorSchedule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendRegistrationConfirmation</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:exclusiveGateway id="Gateway_SlotAvailable" name="Czy termin jest dostępny?" default="Flow_5">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_PatientAcceptsAlternative" name="Pacjent akceptuje nowy termin?" default="Flow_8">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SaveVisitAndSendConfirmationManually" name="Wyślij potwierdzenie ręcznie">
      <bpmn:incoming>Flow_Error_SendRegistrationConfirmation</bpmn:incoming>
      <bpmn:outgoing>Flow_End_ManualConfirmation</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_CollectPatientData" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CollectPatientData" targetRef="Task_SelectPreferredSlot" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_SelectPreferredSlot" targetRef="Task_ValidateSlotAvailability" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_ValidateSlotAvailability" targetRef="Gateway_SlotAvailable" />
    <bpmn:sequenceFlow id="Flow_5" name="tak" sourceRef="Gateway_SlotAvailable" targetRef="Task_AssignDoctor" />
    <bpmn:sequenceFlow id="Flow_6" name="nie" sourceRef="Gateway_SlotAvailable" targetRef="Task_ProposeAlternativeSlot" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_ProposeAlternativeSlot" targetRef="Gateway_PatientAcceptsAlternative" />
    <bpmn:sequenceFlow id="Flow_8" name="tak" sourceRef="Gateway_PatientAcceptsAlternative" targetRef="Task_AssignDoctor" />
    <bpmn:sequenceFlow id="Flow_9" name="nie" sourceRef="Gateway_PatientAcceptsAlternative" targetRef="EndEvent_Cancelled" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_AssignDoctor" targetRef="Task_AddVisitToDoctorSchedule" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_AddVisitToDoctorSchedule" targetRef="Task_SendRegistrationConfirmation" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_SendRegistrationConfirmation" targetRef="EndEvent_Registered" />
    <bpmn:sequenceFlow id="Flow_Error_SendRegistrationConfirmation" targetRef="Task_SaveVisitAndSendConfirmationManually" />
    <bpmn:sequenceFlow id="Flow_End_ManualConfirmation" sourceRef="Task_SaveVisitAndSendConfirmationManually" />
    <bpmn:startEvent id="StartEvent_1" name="Pacjent zgłasza chęć rejestracji w recepcji">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_04wv2j0" />
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_Registered" name="Wizyta zarejestrowana">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_VisitRegisteredToPatient" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Cancelled" name="Rejestracja przerwana">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_07c3wss" />
    </bpmn:endEvent>
    <bpmn:task id="Task_CollectPatientData" name="Wprowadź dane pacjenta i cel wizyty">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SelectPreferredSlot" name="Wybierz preferowany termin wizyty">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ValidateSlotAvailability" name="Sprawdź dostępność terminu">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ProposeAlternativeSlot" name="Zaproponuj alternatywny termin">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AssignDoctor" name="Przypisz lekarza do wizyty">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AddVisitToDoctorSchedule" name="Dodaj wizytę do grafiku lekarza">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SendRegistrationConfirmation" name="Wygeneruj i wyślij potwierdzenie wizyty">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmn:error id="Error_ValidateSlotAvailability" name="Błąd systemu przy sprawdzaniu dostępności terminu" />
  <bpmn:error id="Error_AddVisitToDoctorSchedule" name="Błąd dodawania wizyty do grafiku" />
  <bpmn:error id="Error_SendRegistrationConfirmation" name="Błąd wysyłki potwierdzenia do pacjenta" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_VisitRegistrationClerk">
    <bpmndi:BPMNPlane id="BPMNPlane_VisitRegistrationClerk" bpmnElement="Collab_VisitRegistrationClerk">
      <bpmndi:BPMNShape id="S_Pool_Main" bpmnElement="Pool_VisitRegistrationClerk" isHorizontal="true">
        <dc:Bounds x="120" y="50" width="2560" height="480" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_System" bpmnElement="Lane_System" isHorizontal="true">
        <dc:Bounds x="150" y="270" width="2530" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_Clerk" bpmnElement="Lane_Clerk" isHorizontal="true">
        <dc:Bounds x="150" y="50" width="2530" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Gateway_SlotAvailable" bpmnElement="Gateway_SlotAvailable" isMarkerVisible="true">
        <dc:Bounds x="1120" y="365" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Gateway_PatientAccepts" bpmnElement="Gateway_PatientAcceptsAlternative" isMarkerVisible="true">
        <dc:Bounds x="1540" y="135" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="202" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndEvent_Registered" bpmnElement="EndEvent_Registered">
        <dc:Bounds x="2502" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2418" y="146" width="74" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_12fco7l_di" bpmnElement="EndEvent_Cancelled">
        <dc:Bounds x="1547" y="52" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1481" y="56.5" width="56" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_06mk9vp_di" bpmnElement="Task_CollectPatientData">
        <dc:Bounds x="280" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0sbnf0p_di" bpmnElement="Task_SelectPreferredSlot">
        <dc:Bounds x="560" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1vknh5t_di" bpmnElement="Task_ValidateSlotAvailability">
        <dc:Bounds x="840" y="350" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0os7ok9_di" bpmnElement="Task_ProposeAlternativeSlot">
        <dc:Bounds x="1095" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1h5id2l_di" bpmnElement="Task_AssignDoctor">
        <dc:Bounds x="1710" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1qp14g2_di" bpmnElement="Task_AddVisitToDoctorSchedule">
        <dc:Bounds x="1930" y="350" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_07mlrdw_di" bpmnElement="Task_SendRegistrationConfirmation">
        <dc:Bounds x="2210" y="350" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="238" y="160" />
        <di:waypoint x="280" y="160" />
      </bpmndi:BPMNEdge>
