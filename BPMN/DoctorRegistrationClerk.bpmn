      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Rec_di" bpmnElement="Lane_Rec" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="1170" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="220" y="137" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="204" y="180" width="69" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_1_di" bpmnElement="Task_1">
