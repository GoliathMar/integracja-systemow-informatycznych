  <bpmn:process id="Process_Biznes" isExecutable="false">
    <bpmn:startEvent id="Start_Biznes" name="Decyzja o dodaniu nowej placówki">
      <bpmn:outgoing>Flow_Biz1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Biznes1" name="Sformułowanie żądania">
      <bpmn:incoming>Flow_Biz1</bpmn:incoming>
      <bpmn:outgoing>Flow_Biz2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateThrowEvent id="Throw_ReqToAdmin" name="Wysłanie zlecenia do administracji">
      <bpmn:incoming>Flow_Biz2</bpmn:incoming>
      <bpmn:outgoing>Flow_Biz3</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Catch_SuccessFromAdmin" name="Odbiór potwierdzenia sukcesu">
      <bpmn:incoming>Flow_Biz3</bpmn:incoming>
      <bpmn:outgoing>Flow_Biz4</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="End_Biznes" name="Placówka oficjalnie otwarta">
      <bpmn:incoming>Flow_Biz4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Biz1" sourceRef="Start_Biznes" targetRef="Task_Biznes1" />
