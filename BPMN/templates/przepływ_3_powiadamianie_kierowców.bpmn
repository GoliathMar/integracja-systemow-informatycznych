      <bpmndi:BPMNShape id="S_Task_P3_Anal" bpmnElement="Task_P3_AnalizujExcele">
        <dc:Bounds x="290" y="180" width="160" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_P3_Plan" bpmnElement="Task_P3_UtworzPlanDnia">
        <dc:Bounds x="520" y="180" width="160" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_SubProc_P3_Powiadom" bpmnElement="SubProc_P3_Powiadom" isExpanded="true">
        <dc:Bounds x="750" y="80" width="440" height="260" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start_SubP3" bpmnElement="Start_SubP3">
        <dc:Bounds x="782" y="190" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="763" y="233" width="74" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_P3_Tel" bpmnElement="Task_P3_Zadzwon">
