<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_PatientPortal" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:message id="Msg_DaneLogowania" name="Dane logowania" />
  <bpmn:message id="Msg_WyborAkcji" name="Wybór akcji przez pacjenta" />
  <bpmn:message id="Msg_ZlecenieUmowienia" name="Zlecenie umówienia wizyty" />
  <bpmn:message id="Msg_ZlecenieAnulowania" name="Zlecenie anulowania wizyty" />
  <bpmn:message id="Msg_ZlecenieWylogowania" name="Zlecenie wylogowania" />
  <bpmn:message id="Msg_BladLogowania" name="Błąd logowania" />
  <bpmn:message id="Msg_PotwierdzenieLogowania" name="Potwierdzenie logowania" />
  <bpmn:message id="Msg_PrzekierowanieDoZwrotu" name="Przekierowanie do zwrotu płatności" />
  <bpmn:message id="Msg_StatusZwrotu" name="Status zwrotu płatności" />
  <bpmn:message id="Msg_PrzekierowanieDoPlatnosci" name="Przekierowanie do płatności" />
  <bpmn:message id="Msg_StatusPlatnosci" name="Status płatności" />
  <bpmn:message id="Msg_PowiadomieniePacjentaAnulowanie" name="Potwierdzenie anulowania wizyty" />
  <bpmn:message id="Msg_PowiadomieniePacjentaRezerwacja" name="Potwierdzenie rezerwacji i płatności" />
  <bpmn:message id="Msg_PowiadomieniePacjentaZwrot" name="Potwierdzenie zwrotu płatności" />
  <bpmn:message id="Msg_WylogowanieOK" name="Wylogowanie potwierdzone" />
  <bpmn:collaboration id="Collab_PatientPortal">
    <bpmn:participant id="Pool_Pacjent" name="Pacjent" processRef="Proc_Pacjent" />
    <bpmn:participant id="Pool_System" name="System Medyczny" processRef="Proc_System" />
    <bpmn:participant id="Pool_SysPlatniczy" name="System Płatniczy" processRef="Proc_SysPlatniczy" />
    <bpmn:messageFlow id="MF_DaneLogowania" name="Dane logowania" sourceRef="Task_WprowadzDane" targetRef="Start_SystemOtrzymujeDane" />
    <bpmn:messageFlow id="MF_BladLogowania" name="Błąd logowania" sourceRef="Task_WyslijBladLogowania" targetRef="Catch_PacjentBladLogowania" />
    <bpmn:messageFlow id="MF_PotwierdzenieLogowania" name="Potwierdzenie logowania" sourceRef="Task_WyslijPotwierdzenieLogowania" targetRef="Catch_PacjentZalogowany" />
    <bpmn:messageFlow id="MF_WyborAkcji" name="Wybór akcji" sourceRef="Task_WybierzAkcje" targetRef="Catch_SystemWyborAkcji" />
    <bpmn:messageFlow id="MF_ZlecenieUmowienia" name="Zlecenie umówienia wizyty" sourceRef="End_PacjentZlecaUmowienie" targetRef="Catch_SystemUmawianie" />
    <bpmn:messageFlow id="MF_ZlecenieAnulowania" name="Zlecenie anulowania wizyty" sourceRef="End_PacjentZlecaAnulowanie" targetRef="Catch_SystemAnulowanie" />
    <bpmn:messageFlow id="MF_ZlecenieWylogowania" name="Zlecenie wylogowania" sourceRef="End_PacjentWylogowuje" targetRef="Catch_SystemWylogowanie" />
    <bpmn:messageFlow id="MF_PotwierdzenieRezerwacji" name="Potwierdzenie rezerwacji i płatności" sourceRef="Task_WyslijPotwierdzenieRezerwacji" targetRef="Catch_PacjentPotwierdzRezerwacji" />
    <bpmn:messageFlow id="MF_PotwierdzenieAnulowania" name="Potwierdzenie anulowania wizyty" sourceRef="Task_WyslijPotwierdzenieAnulowania" targetRef="Catch_PacjentPotwierdzAnulowania" />
    <bpmn:messageFlow id="MF_PotwierdzenieZwrotu" name="Potwierdzenie zwrotu płatności" sourceRef="Task_WyslijPotwierdzenieZwrotu" targetRef="Catch_PacjentPotwierdzZwrotu" />
    <bpmn:messageFlow id="MF_PotwierdzenieWylogowania" name="Potwierdzenie wylogowania" sourceRef="End_SystemWylogowanie" targetRef="Catch_PacjentWylogowany" />
    <bpmn:messageFlow id="MF_PrzekierowanieDoZwrotu" name="Zlecenie zwrotu płatności" sourceRef="Task_PrzekierujDoZwrotu" targetRef="Start_SysZwrot" />
    <bpmn:messageFlow id="MF_StatusZwrotu" name="Status zwrotu" sourceRef="End_SysZwrotOK" targetRef="Catch_SystemStatusZwrotu" />
    <bpmn:messageFlow id="MF_PrzekerowanieDoPlatnosci" name="Zlecenie płatności" sourceRef="Task_PrzekierujDoPlatnosci" targetRef="Start_SysPlatnosc" />
    <bpmn:messageFlow id="MF_StatusPlatnosci" name="Status płatności" sourceRef="End_SysPlatnoscOK" targetRef="Catch_SystemStatusPlatnosci" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_Pacjent" isExecutable="false">
    <bpmn:startEvent id="Start_Pacjent" name="Otwiera portal medyczny">
      <bpmn:outgoing>SF_PA_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_WprowadzDane" name="Wprowadza login i hasło">
      <bpmn:incoming>SF_PA_01</bpmn:incoming>
      <bpmn:incoming>SF_PA_Retry</bpmn:incoming>
      <bpmn:outgoing>SF_PA_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:eventBasedGateway id="GW_PA_OdpLogowania" name="Oczekiwanie na odpowiedź systemu">
      <bpmn:incoming>SF_PA_02</bpmn:incoming>
      <bpmn:outgoing>SF_PA_Blad</bpmn:outgoing>
      <bpmn:outgoing>SF_PA_OK</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Catch_PacjentBladLogowania" name="Otrzymuje informację o błędzie logowania">
      <bpmn:incoming>SF_PA_Blad</bpmn:incoming>
      <bpmn:outgoing>SF_PA_Retry</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_PA_Blad" messageRef="Msg_BladLogowania" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_WybierzAkcje" name="Wybiera akcję w portalu">
      <bpmn:incoming>Flow_1kdgs1a</bpmn:incoming>
      <bpmn:outgoing>SF_PA_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Catch_PacjentZalogowany" name="Otrzymuje potwierdzenie zalogowania">
      <bpmn:incoming>SF_PA_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_1kdgs1a</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_PA_OK" messageRef="Msg_PotwierdzenieLogowania" />
    </bpmn:intermediateCatchEvent>
    <bpmn:startEvent id="Catch_PacjentPotwierdzAnulowania" name="Otrzymuje potwierdzenie anulowania wizyty">
      <bpmn:outgoing>SF_PA_EndAnulBezZwrotu</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_PA_PotAnul" messageRef="Msg_PowiadomieniePacjentaAnulowanie" />
    </bpmn:startEvent>
    <bpmn:endEvent id="End_PacjentZwrot" name="Wizyta anulowana, płatność zwrócona">
      <bpmn:incoming>SF_PA_EndAnulZeZwrotem</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_PA_WyborAkcji" name="Jaka akcja?">
      <bpmn:incoming>SF_PA_04</bpmn:incoming>
      <bpmn:outgoing>SF_PA_Umow</bpmn:outgoing>
      <bpmn:outgoing>SF_PA_Anuluj</bpmn:outgoing>
      <bpmn:outgoing>SF_PA_Wyloguj</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_PacjentZlecaUmowienie" name="Zleca umówienie wizyty">
      <bpmn:incoming>SF_PA_Umow</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_PA_ZlecUmow" messageRef="Msg_ZlecenieUmowienia" />
    </bpmn:endEvent>
    <bpmn:endEvent id="End_PacjentWylogowuje" name="Zleca wylogowanie">
      <bpmn:incoming>SF_PA_Wyloguj</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_PA_Wyloguj" messageRef="Msg_ZlecenieWylogowania" />
    </bpmn:endEvent>
    <bpmn:endEvent id="End_PacjentZlecaAnulowanie" name="Zleca anulowanie wizyty">
      <bpmn:incoming>SF_PA_Anuluj</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_PA_ZlecAnul" messageRef="Msg_ZlecenieAnulowania" />
    </bpmn:endEvent>
    <bpmn:startEvent id="Catch_PacjentWylogowany" name="Otrzymuje potwierdzenie wylogowania">
      <bpmn:outgoing>SF_PA_EndWyloguj</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_PA_WylogOK" messageRef="Msg_WylogowanieOK" />
    </bpmn:startEvent>
    <bpmn:endEvent id="End_PacjentWylogowany" name="Wylogowany z portalu">
      <bpmn:incoming>SF_PA_EndWyloguj</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="Catch_PacjentPotwierdzZwrotu" name="Otrzymuje potwierdzenie zwrotu płatności">
      <bpmn:outgoing>SF_PA_EndAnulZeZwrotem</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_PA_PotZwrot" messageRef="Msg_PowiadomieniePacjentaZwrot" />
    </bpmn:startEvent>
    <bpmn:endEvent id="End_PacjentAnulowanie" name="Wizyta anulowana">
      <bpmn:incoming>SF_PA_EndAnulBezZwrotu</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="Catch_PacjentPotwierdzRezerwacji" name="Otrzymuje potwierdzenie rezerwacji i płatności">
      <bpmn:outgoing>SF_PA_EndUmow</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_PA_PotRez" messageRef="Msg_PowiadomieniePacjentaRezerwacja" />
    </bpmn:startEvent>
    <bpmn:endEvent id="End_PacjentRezerwacja" name="Wizyta umówiona i opłacona">
      <bpmn:incoming>SF_PA_EndUmow</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_PA_01" sourceRef="Start_Pacjent" targetRef="Task_WprowadzDane" />
    <bpmn:sequenceFlow id="SF_PA_Retry" sourceRef="Catch_PacjentBladLogowania" targetRef="Task_WprowadzDane" />
    <bpmn:sequenceFlow id="SF_PA_02" sourceRef="Task_WprowadzDane" targetRef="GW_PA_OdpLogowania" />
    <bpmn:sequenceFlow id="SF_PA_Blad" sourceRef="GW_PA_OdpLogowania" targetRef="Catch_PacjentBladLogowania" />
    <bpmn:sequenceFlow id="SF_PA_OK" sourceRef="GW_PA_OdpLogowania" targetRef="Catch_PacjentZalogowany" />
    <bpmn:sequenceFlow id="Flow_1kdgs1a" sourceRef="Catch_PacjentZalogowany" targetRef="Task_WybierzAkcje" />
    <bpmn:sequenceFlow id="SF_PA_04" sourceRef="Task_WybierzAkcje" targetRef="GW_PA_WyborAkcji" />
    <bpmn:sequenceFlow id="SF_PA_EndAnulBezZwrotu" sourceRef="Catch_PacjentPotwierdzAnulowania" targetRef="End_PacjentAnulowanie" />
    <bpmn:sequenceFlow id="SF_PA_EndAnulZeZwrotem" sourceRef="Catch_PacjentPotwierdzZwrotu" targetRef="End_PacjentZwrot" />
    <bpmn:sequenceFlow id="SF_PA_Umow" name="Umów wizytę" sourceRef="GW_PA_WyborAkcji" targetRef="End_PacjentZlecaUmowienie" />
    <bpmn:sequenceFlow id="SF_PA_Anuluj" name="Anuluj wizytę" sourceRef="GW_PA_WyborAkcji" targetRef="End_PacjentZlecaAnulowanie" />
    <bpmn:sequenceFlow id="SF_PA_Wyloguj" name="Wyloguj" sourceRef="GW_PA_WyborAkcji" targetRef="End_PacjentWylogowuje" />
    <bpmn:sequenceFlow id="SF_PA_EndWyloguj" sourceRef="Catch_PacjentWylogowany" targetRef="End_PacjentWylogowany" />
    <bpmn:sequenceFlow id="SF_PA_EndUmow" sourceRef="Catch_PacjentPotwierdzRezerwacji" targetRef="End_PacjentRezerwacja" />
  </bpmn:process>
  <bpmn:process id="Proc_System" isExecutable="false">
    <bpmn:endEvent id="End_SystemBladLogowania" name="Sesja nieudana">
      <bpmn:incoming>SF_SY_EndBlad</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_WyslijBladLogowania" name="Wysyła komunikat o błędzie logowania">
      <bpmn:incoming>SF_SY_Blad</bpmn:incoming>
      <bpmn:outgoing>SF_SY_EndBlad</bpmn:outgoing>
    </bpmn:task>
    <bpmn:startEvent id="Start_SystemOtrzymujeDane" name="Otrzymuje dane logowania">
      <bpmn:outgoing>SF_SY_01</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SY_Start" messageRef="Msg_DaneLogowania" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_SY_DaneOK" name="Czy dane poprawne?">
      <bpmn:incoming>SF_SY_01</bpmn:incoming>
      <bpmn:outgoing>SF_SY_Blad</bpmn:outgoing>
      <bpmn:outgoing>SF_SY_Zalogowany</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_WyslijPotwierdzenieLogowania" name="Wysyła potwierdzenie zalogowania">
      <bpmn:incoming>SF_SY_Zalogowany</bpmn:incoming>
      <bpmn:outgoing>SF_SY_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Catch_SystemWyborAkcji" name="Odbiera wybór akcji">
      <bpmn:incoming>SF_SY_02</bpmn:incoming>
      <bpmn:outgoing>SF_SY_03</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SY_WyborAkcji" messageRef="Msg_WyborAkcji" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="GW_SY_AkcjaRozgalezienie" name="Jaka akcja?">
      <bpmn:incoming>SF_SY_03</bpmn:incoming>
      <bpmn:outgoing>SF_SY_Umow</bpmn:outgoing>
      <bpmn:outgoing>SF_SY_Anuluj</bpmn:outgoing>
      <bpmn:outgoing>SF_SY_Wyloguj</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateCatchEvent id="Catch_SystemAnulowanie" name="Odbiera zlecenie anulowania wizyty">
      <bpmn:incoming>SF_SY_Anuluj</bpmn:incoming>
      <bpmn:outgoing>SF_SY_A1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SY_Anul" messageRef="Msg_ZlecenieAnulowania" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Catch_SystemWylogowanie" name="Odbiera zlecenie wylogowania">
      <bpmn:incoming>SF_SY_Wyloguj</bpmn:incoming>
      <bpmn:outgoing>SF_SY_W1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SY_Wyloguj" messageRef="Msg_ZlecenieWylogowania" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Catch_SystemUmawianie" name="Odbiera zlecenie umówienia wizyty">
      <bpmn:incoming>SF_SY_Umow</bpmn:incoming>
      <bpmn:outgoing>SF_SY_U1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SY_Umow" messageRef="Msg_ZlecenieUmowienia" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="End_SystemWylogowanie" name="Sesja zakończona — wylogowanie potwierdzone">
      <bpmn:incoming>SF_SY_W1</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_SY_WylogEnd" messageRef="Msg_WylogowanieOK" />
    </bpmn:endEvent>
    <bpmn:task id="Task_PrzekierujDoZwrotu" name="Przekierowuje zlecenie zwrotu do Systemu Płatniczego">
      <bpmn:incoming>SF_SY_A_Tak</bpmn:incoming>
      <bpmn:outgoing>SF_SY_A3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Catch_SystemStatusZwrotu" name="Odbiera status zwrotu płatności">
      <bpmn:incoming>SF_SY_A3</bpmn:incoming>
      <bpmn:outgoing>SF_SY_A4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SY_StatZwrot" messageRef="Msg_StatusZwrotu" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_SprawdzWolnyTermin" name="Sprawdza dostępny termin i lekarza">
      <bpmn:incoming>SF_SY_U1</bpmn:incoming>
      <bpmn:outgoing>SF_SY_U2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_SY_TerminDostepny" name="Czy termin dostępny?">
      <bpmn:incoming>SF_SY_U2</bpmn:incoming>
      <bpmn:outgoing>SF_SY_U_Tak</bpmn:outgoing>
      <bpmn:outgoing>SF_SY_U_Nie</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_PrzekierujDoPlatnosci" name="Przekierowuje do płatności">
      <bpmn:incoming>SF_SY_U_Tak</bpmn:incoming>
      <bpmn:outgoing>SF_SY_U3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Catch_SystemStatusPlatnosci" name="Odbiera status płatności">
      <bpmn:incoming>SF_SY_U3</bpmn:incoming>
      <bpmn:outgoing>SF_SY_U4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SY_StatPl" messageRef="Msg_StatusPlatnosci" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_ZarezerwujWizyte" name="Tworzy rezerwację wizyty w systemie">
      <bpmn:incoming>SF_SY_U4</bpmn:incoming>
      <bpmn:outgoing>SF_SY_U5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_WyslijPotwierdzenieRezerwacji" name="Wysyła potwierdzenie rezerwacji i płatności do Pacjenta">
      <bpmn:incoming>SF_SY_U5</bpmn:incoming>
      <bpmn:outgoing>SF_SY_U6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_SystemRezerwacja" name="Wizyta zarezerwowana">
      <bpmn:incoming>SF_SY_U6</bpmn:incoming>
      <bpmn:incoming>SF_SY_U_Nie</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_SY_CzyPlatnosc" name="Czy wizyta była opłacona?">
      <bpmn:incoming>SF_SY_A2</bpmn:incoming>
      <bpmn:outgoing>SF_SY_A_Tak</bpmn:outgoing>
      <bpmn:outgoing>SF_SY_A_Nie</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AnulujRezerwacje" name="Anuluje rezerwację w systemie">
      <bpmn:incoming>SF_SY_A1</bpmn:incoming>
      <bpmn:outgoing>SF_SY_A2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_WyslijPotwierdzenieZwrotu" name="Wysyła potwierdzenie zwrotu płatności do Pacjenta">
      <bpmn:incoming>SF_SY_A4</bpmn:incoming>
      <bpmn:outgoing>SF_SY_A5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_WyslijPotwierdzenieAnulowania" name="Wysyła potwierdzenie anulowania do Pacjenta">
      <bpmn:incoming>SF_SY_A_Nie</bpmn:incoming>
      <bpmn:outgoing>SF_SY_A6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_SystemAnulowanieBezZwrotu" name="Wizyta anulowana bez zwrotu">
      <bpmn:incoming>SF_SY_A6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_SystemAnulowanieZeZwrotem" name="Wizyta anulowana ze zwrotem">
      <bpmn:incoming>SF_SY_A5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_SY_EndBlad" sourceRef="Task_WyslijBladLogowania" targetRef="End_SystemBladLogowania" />
    <bpmn:sequenceFlow id="SF_SY_Blad" name="Nie" sourceRef="GW_SY_DaneOK" targetRef="Task_WyslijBladLogowania" />
    <bpmn:sequenceFlow id="SF_SY_01" sourceRef="Start_SystemOtrzymujeDane" targetRef="GW_SY_DaneOK" />
    <bpmn:sequenceFlow id="SF_SY_Zalogowany" name="Tak" sourceRef="GW_SY_DaneOK" targetRef="Task_WyslijPotwierdzenieLogowania" />
    <bpmn:sequenceFlow id="SF_SY_02" sourceRef="Task_WyslijPotwierdzenieLogowania" targetRef="Catch_SystemWyborAkcji" />
    <bpmn:sequenceFlow id="SF_SY_03" sourceRef="Catch_SystemWyborAkcji" targetRef="GW_SY_AkcjaRozgalezienie" />
    <bpmn:sequenceFlow id="SF_SY_Umow" name="Umów wizytę" sourceRef="GW_SY_AkcjaRozgalezienie" targetRef="Catch_SystemUmawianie" />
    <bpmn:sequenceFlow id="SF_SY_Anuluj" name="Anuluj wizytę" sourceRef="GW_SY_AkcjaRozgalezienie" targetRef="Catch_SystemAnulowanie" />
    <bpmn:sequenceFlow id="SF_SY_Wyloguj" name="Wyloguj" sourceRef="GW_SY_AkcjaRozgalezienie" targetRef="Catch_SystemWylogowanie" />
    <bpmn:sequenceFlow id="SF_SY_A1" sourceRef="Catch_SystemAnulowanie" targetRef="Task_AnulujRezerwacje" />
